---
type Props = {
  title: string;
  description: string;
  socialImage?: string;
};

const { title, description, socialImage } = Astro.props;
const isDev = import.meta.env.DEV;
const siteUrl = import.meta.env.PUBLIC_SITE_URL ?? Astro.site?.toString() ?? 'http://localhost:4321';
const siteOrigin = new URL(siteUrl);
const consoleUrl = import.meta.env.PUBLIC_CONSOLE_URL ?? (isDev ? 'http://localhost:3000' : siteUrl);
const deployUrl = new URL('/deploy', consoleUrl).toString();
const canonicalUrl = new URL(Astro.url.pathname, siteOrigin).toString();
const socialImageUrl = socialImage ? new URL(socialImage, siteOrigin).toString() : new URL('/social-card.svg', siteOrigin).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow" />
    <meta name="theme-color" content="#060a12" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Comnetish" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImageUrl} />
    <meta property="og:image:alt" content="Comnetish decentralized cloud marketing card" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageUrl} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Syne:wght@500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      document.documentElement.dataset.js = 'true';
    </script>
    <style>
      :root {
        --bg: #060a12;
        --surface: #0f1827;
        --surface-soft: #111d2f;
        --text: #e7eef8;
        --muted: #9bb0c7;
        --mint: #00ffc2;
        --mint-soft: rgba(0, 255, 194, 0.14);
        --border: rgba(255, 255, 255, 0.1);
        --danger: #ff6b35;
        --focus: #8fd3ff;
        --content-max: 1240px;
        --content-pad: clamp(20px, 4vw, 48px);
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        margin: 0;
        padding: 0;
        background: radial-gradient(circle at 15% 0%, rgba(0, 255, 194, 0.08), transparent 36%),
          radial-gradient(circle at 85% 0%, rgba(114, 141, 255, 0.09), transparent 35%), var(--bg);
        color: var(--text);
        font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
        min-height: 100%;
        overflow-x: hidden;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      :global(.wrap) {
        width: min(var(--content-max), calc(100% - (var(--content-pad) * 2)));
        padding-inline: 0;
        margin: 0 auto;
      }

      main {
        padding-bottom: 1.5rem;
      }

      header.site {
        position: sticky;
        top: 0;
        backdrop-filter: blur(10px);
        background: rgba(6, 10, 18, 0.72);
        border-bottom: 1px solid var(--border);
        z-index: 20;
      }

      .nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 72px;
      }

      .brand {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        font-family: Syne, Inter, sans-serif;
        font-weight: 700;
        letter-spacing: 0.2px;
      }

      .dot {
        width: 10px;
        height: 10px;
        border-radius: 999px;
        background: var(--mint);
        box-shadow: 0 0 18px rgba(0, 255, 194, 0.7);
      }

      .navLinks {
        display: inline-flex;
        align-items: center;
        flex-wrap: wrap;
        justify-content: flex-end;
        gap: 22px;
        color: var(--muted);
        font-size: 0.95rem;
      }

      :global(.btn) {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 10px;
        border: 1px solid var(--border);
        padding: 0.78rem 1.05rem;
        font-weight: 600;
        transition: transform 140ms ease, border-color 140ms ease, box-shadow 140ms ease;
      }

      :global(.btn:hover) {
        transform: translateY(-1px);
      }

      :global(.btn:disabled) {
        opacity: 0.7;
        cursor: wait;
        transform: none;
      }

      :global(.btnPrimary) {
        background: linear-gradient(135deg, #00ffc2, #78ffd9);
        color: #021117;
        border-color: transparent;
        box-shadow: 0 10px 28px rgba(0, 255, 194, 0.25);
      }

      :global(.btnGhost) {
        background: rgba(255, 255, 255, 0.02);
      }

      :global(section) {
        scroll-margin-top: 110px;
      }

      :global(.section) {
        padding: 76px 0;
      }

      :global(.sectionTitle) {
        margin: 0;
        font-family: Syne, Inter, sans-serif;
        font-size: clamp(1.5rem, 2.5vw, 2.2rem);
      }

      :global(.sectionSub) {
        color: var(--muted);
        margin: 10px 0 0;
      }

      :global(.card) {
        border: 1px solid var(--border);
        background: linear-gradient(180deg, rgba(18, 26, 41, 0.82), rgba(11, 17, 29, 0.86));
        border-radius: 16px;
      }

      :global([data-reveal]) {
        opacity: 1;
        transform: none;
      }

      html[data-js='true'] :global([data-reveal]) {
        opacity: 0;
        transform: translateY(12px);
        transition: opacity 560ms ease, transform 560ms ease;
      }

      html[data-js='true'] :global([data-reveal].in) {
        opacity: 1;
        transform: translateY(0);
      }

      :global(a:focus-visible),
      :global(button:focus-visible),
      :global(input:focus-visible) {
        outline: 2px solid var(--focus);
        outline-offset: 3px;
      }

      .footer {
        border-top: 1px solid var(--border);
        padding: 28px 0 42px;
        color: var(--muted);
        font-size: 0.9rem;
      }

      @media (max-width: 860px) {
        .nav {
          height: auto;
          flex-wrap: wrap;
          gap: 12px;
          padding: 16px 0;
        }

        .navLinks {
          width: 100%;
          justify-content: center;
          gap: 12px;
        }

        .navLinks .btn {
          width: auto;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        html[data-js='true'] :global([data-reveal]),
        html[data-js='true'] :global([data-reveal].in) {
          opacity: 1;
          transform: none;
          transition: none;
        }
      }
    </style>
  </head>
  <body>
    <header class="site">
      <div class="wrap nav">
        <a href="/" class="brand" aria-label="Comnetish home">
          <span class="dot"></span>
          <span>Comnetish</span>
        </a>
        <nav class="navLinks" aria-label="Primary">
          <a href="/">Home</a>
          <a href="/providers">Providers</a>
          <a href="/docs">Docs</a>
          <a class="btn btnGhost" href={deployUrl}>Deploy Now</a>
        </nav>
      </div>
    </header>
    <slot />
    <footer class="footer">
      <div class="wrap">© {new Date().getFullYear()} Comnetish. Decentralized cloud compute marketplace.</div>
    </footer>

    <script>
      const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const revealTargets = Array.from(document.querySelectorAll<HTMLElement>('[data-reveal]'));
      if (reducedMotion || !('IntersectionObserver' in window)) {
        for (const node of revealTargets) {
          node.classList.add('in');
        }
      } else {
        const observer = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('in');
                observer.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.16 }
        );

        for (const node of revealTargets) {
          observer.observe(node);
        }
      }

      const statsEl = document.querySelector<HTMLElement>('[data-live-stats]');
      const API_BASE = statsEl?.dataset.api?.trim() || '';
      if (statsEl) {
        const providersNode = statsEl.querySelector<HTMLElement>('[data-stat="providers"]');
        const deploymentsNode = statsEl.querySelector<HTMLElement>('[data-stat="deployments"]');
        const volumeNode = statsEl.querySelector<HTMLElement>('[data-stat="volume"]');
        const statusNode = statsEl.querySelector<HTMLElement>('[data-stats-status]');
        const providersFallback = providersNode?.textContent?.trim() || '0';
        const deploymentsFallback = deploymentsNode?.textContent?.trim() || '0';
        const volumeFallback = volumeNode?.textContent?.trim() || '0 CNT';

        const setValue = (el: HTMLElement | null, value: string) => {
          if (el) {
            el.textContent = value;
          }
        };

        const setStatus = (value: string) => {
          if (statusNode) {
            statusNode.textContent = value;
          }
        };

        if (!API_BASE) {
          setStatus('Live metrics are unavailable because the website API URL is not configured.');
          setValue(providersNode, providersFallback);
          setValue(deploymentsNode, deploymentsFallback);
          setValue(volumeNode, volumeFallback);
        } else {
          const loadStats = async () => {
            const controller = new AbortController();
            const timeoutId = window.setTimeout(() => controller.abort(), 8000);

            try {
              setStatus('Loading live network metrics...');
              const apiRoot = API_BASE.replace(/\/$/, '');
              const withApiPrefix = (path: string) => (apiRoot.endsWith('/api') ? `${apiRoot}${path}` : `${apiRoot}/api${path}`);
              const [providerRes, platformRes] = await Promise.all([
                fetch(withApiPrefix('/providers/stats'), { signal: controller.signal }),
                fetch(withApiPrefix('/stats'), { signal: controller.signal })
              ]);

              if (!providerRes.ok || !platformRes.ok) {
                throw new Error('failed');
              }

              const providerPayload = await providerRes.json();
              const platformPayload = await platformRes.json();
              const providers = providerPayload?.data?.active ?? providerPayload?.data?.total ?? 0;
              const deployments = platformPayload?.data?.totalDeployments ?? 0;
              const volume = platformPayload?.data?.cntVolume ?? 0;

              setValue(providersNode, Number(providers).toLocaleString());
              setValue(deploymentsNode, Number(deployments).toLocaleString());
              setValue(volumeNode, `${Number(volume).toLocaleString()} CNT`);
              setStatus('Live metrics update automatically every 30 seconds.');
            } catch {
              setValue(providersNode, providersFallback);
              setValue(deploymentsNode, deploymentsFallback);
              setValue(volumeNode, volumeFallback);
              setStatus('Live metrics are temporarily unavailable.');
            } finally {
              window.clearTimeout(timeoutId);
            }
          };

          loadStats();
          window.setInterval(loadStats, 30_000);
        }
      }

      const calculatorRoots = Array.from(document.querySelectorAll<HTMLElement>('[data-earnings-calculator]'));
      for (const root of calculatorRoots) {
        const cpuInput = root.querySelector<HTMLInputElement>('[data-input="cpu"]');
        const ramInput = root.querySelector<HTMLInputElement>('[data-input="ram"]');
        const cpuOut = root.querySelector<HTMLElement>('[data-output="cpu"]');
        const ramOut = root.querySelector<HTMLElement>('[data-output="ram"]');
        const cntOut = root.querySelector<HTMLElement>('[data-output="cnt"]');
        const usdOut = root.querySelector<HTMLElement>('[data-output="usd"]');
        const summaryOut = root.querySelector<HTMLElement>('[data-output="summary"]');

        const compute = () => {
          const cpu = Number(cpuInput?.value || 2);
          const ram = Number(ramInput?.value || 4);
          const cntMonthly = cpu * 230 + ram * 38;
          const usdMonthly = cntMonthly * 0.19;

          if (cpuOut) cpuOut.textContent = String(cpu);
          if (ramOut) ramOut.textContent = String(ram);
          if (cntOut) cntOut.textContent = `${cntMonthly.toLocaleString()} CNT`;
          if (usdOut) usdOut.textContent = `$${usdMonthly.toFixed(2)}`;
          cpuInput?.setAttribute('aria-valuenow', String(cpu));
          cpuInput?.setAttribute('aria-valuetext', `${cpu} CPU cores`);
          ramInput?.setAttribute('aria-valuenow', String(ram));
          ramInput?.setAttribute('aria-valuetext', `${ram} gigabytes of RAM`);
          if (summaryOut) {
            summaryOut.textContent = `${cpu} CPU cores and ${ram} GB RAM estimate ${cntMonthly.toLocaleString()} CNT or $${usdMonthly.toFixed(2)} per month.`;
          }
        };

        cpuInput?.addEventListener('input', compute);
        ramInput?.addEventListener('input', compute);
        compute();
      }

      const captureForm = document.querySelector<HTMLFormElement>('[data-email-capture]');
      if (captureForm) {
        const statusNode = captureForm.querySelector<HTMLElement>('[data-capture-status]');
        const emailInput = captureForm.querySelector<HTMLInputElement>('input[type="email"]');
        const submitButton = captureForm.querySelector<HTMLButtonElement>('button[type="submit"]');
        const sourceInput = captureForm.querySelector<HTMLInputElement>('input[name="source"]');
        const jsonAction = captureForm.dataset.jsonAction || captureForm.action;

        captureForm.addEventListener('submit', async (event) => {
          event.preventDefault();
          const value = emailInput?.value?.trim() || '';
          if (!emailInput?.checkValidity() || !value) {
            emailInput?.reportValidity();
            if (statusNode) statusNode.textContent = 'Enter a valid email address.';
            return;
          }

          if (!jsonAction) {
            if (statusNode) statusNode.textContent = 'Waitlist submission is unavailable right now.';
            return;
          }

          try {
            if (submitButton) {
              submitButton.disabled = true;
            }
            if (statusNode) {
              statusNode.textContent = 'Joining waitlist...';
            }

            const response = await fetch(jsonAction, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ email: value, source: sourceInput?.value || 'website' })
            });

            if (!response.ok) {
              throw new Error('waitlist-submit-failed');
            }

            if (statusNode) statusNode.textContent = 'You are on the waitlist. We will reach out shortly.';
            captureForm.reset();
          } catch {
            if (statusNode) statusNode.textContent = 'Failed to join waitlist. Please try again.';
          } finally {
            if (submitButton) {
              submitButton.disabled = false;
            }
          }
        });
      }
    </script>
  </body>
</html>
