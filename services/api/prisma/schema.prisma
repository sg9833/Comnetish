generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String                   @id @default(cuid())
  email                   String?                  @unique
  emailVerifiedAt         DateTime?
  passwordHash            String?
  displayName             String?
  avatarUrl               String?
  primaryRole             UserRole                 @default(TENANT)
  status                  UserStatus               @default(ACTIVE)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  wallets                 LinkedWallet[]
  oauthAccounts           OAuthAccount[]
  sessions                Session[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  authChallenges          AuthChallenge[]
  provider                Provider?
  deployments             Deployment[]
  providerProfile         ProviderProfile?
  tenantProfile           TenantProfile?
}

model LinkedWallet {
  id         String          @id @default(cuid())
  userId     String
  chainType  WalletChainType
  address    String
  isPrimary  Boolean         @default(false)
  verifiedAt DateTime?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chainType, address])
  @@index([userId])
  @@index([userId, isPrimary])
}

model OAuthAccount {
  id                String   @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String
  email             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id               String      @id @default(cuid())
  userId           String
  sessionType      SessionType @default(BROWSER)
  refreshTokenHash String      @unique
  userAgent        String?
  ipAddress        String?
  expiresAt        DateTime
  lastRefreshedAt  DateTime    @default(now())
  revokedAt        DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model AuthChallenge {
  id            String            @id @default(cuid())
  userId        String?
  challengeType AuthChallengeType
  chainType     WalletChainType?
  walletAddress String?
  nonce         String            @unique
  message       String
  expiresAt     DateTime
  consumedAt    DateTime?
  createdAt     DateTime          @default(now())
  user          User?             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([walletAddress])
  @@index([challengeType, expiresAt])
}

model ProviderProfile {
  id              String    @id @default(cuid())
  userId          String    @unique
  providerId      String?   @unique
  onboardingState String    @default("PENDING")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider        Provider? @relation(fields: [providerId], references: [id], onDelete: SetNull)
}

model TenantProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Provider {
  id          String           @id @default(cuid())
  userId      String?          @unique
  address     String           @unique
  region      String
  cpu         Int
  memory      Int
  storage     Int
  pricePerCpu Float
  status      ProviderStatus   @default(ACTIVE)
  lastSeen    DateTime         @default(now())
  bids        Bid[]
  leases      Lease[]
  user        User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  profile     ProviderProfile?

  @@index([region])
  @@index([status])
}

model Deployment {
  id            String           @id @default(cuid())
  userId        String?
  tenantAddress String
  sdl           String
  status        DeploymentStatus @default(OPEN)
  createdAt     DateTime         @default(now())
  closedAt      DateTime?
  bids          Bid[]
  leases        Lease[]
  user          User?            @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([tenantAddress])
  @@index([status])
}

model Lease {
  id            String      @id @default(cuid())
  deploymentId  String
  providerId    String
  status        LeaseStatus @default(PENDING)
  startedAt     DateTime    @default(now())
  pricePerBlock Float
  deployment    Deployment  @relation(fields: [deploymentId], references: [id], onDelete: Cascade)
  provider      Provider    @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([deploymentId])
  @@index([providerId])
}

model Bid {
  id           String     @id @default(cuid())
  deploymentId String
  providerId   String
  price        Float
  status       BidStatus  @default(OPEN)
  createdAt    DateTime   @default(now())
  deployment   Deployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)
  provider     Provider   @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([deploymentId])
  @@index([providerId])
  @@index([createdAt])
}

model Transaction {
  id        String   @id @default(cuid())
  type      String
  from      String
  to        String
  amount    Float
  token     String
  txHash    String   @unique
  createdAt DateTime @default(now())

  @@index([token])
  @@index([createdAt])
}

model WaitlistEntry {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String   @default("website")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
}

enum ProviderStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum DeploymentStatus {
  OPEN
  ACTIVE
  CLOSED
}

enum LeaseStatus {
  PENDING
  ACTIVE
  CLOSED
}

enum BidStatus {
  OPEN
  WON
  LOST
}

enum UserRole {
  TENANT
  PROVIDER
  ADMIN
}

enum UserStatus {
  ACTIVE
  PENDING_VERIFICATION
  SUSPENDED
  DELETED
}

enum WalletChainType {
  EVM
  COSMOS
}

enum SessionType {
  BROWSER
  API_TOKEN
  PROVIDER_CONSOLE
}

enum AuthChallengeType {
  WALLET_SIGN_IN
  WALLET_LINK
  PROVIDER_SIGN_IN
}
