NODE_ENV=development
API_PORT=3001
API_HOST=0.0.0.0
API_CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:3002

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/comnetish

AUTH_RATE_LIMIT_LOGIN_MAX=5
AUTH_RATE_LIMIT_LOGIN_WINDOW_MS=60000
AUTH_RATE_LIMIT_SIGNUP_MAX=10
AUTH_RATE_LIMIT_SIGNUP_WINDOW_MS=60000
AUTH_RATE_LIMIT_PASSWORD_FORGOT_MAX=3
AUTH_RATE_LIMIT_PASSWORD_FORGOT_WINDOW_MS=3600000
AUTH_RATE_LIMIT_PASSWORD_RESET_MAX=5
AUTH_RATE_LIMIT_PASSWORD_RESET_WINDOW_MS=300000

ANTHROPIC_API_KEY=
ANTHROPIC_API_URL=https://api.anthropic.com/v1/messages
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Cosmos chain configuration
COMNETISH_RPC_URL=http://localhost:26657
COMNETISH_REST_URL=http://localhost:1317
COMNETISH_CHAIN_ID=comnetish-1
COMNETISH_GAS_PRICE=0.025ucnt
COMNETISH_RELAYER_MNEMONIC=
COMNETISH_MOCK=false
