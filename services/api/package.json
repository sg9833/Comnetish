{
  "name": "@comnetish/api",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "bun run prisma/seed.ts"
  },
  "dependencies": {
    "@comnetish/types": "workspace:*",
    "@hono/zod-validator": "^0.4.3",
    "@prisma/client": "^6.5.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.4.7",
    "hono": "^4.6.13",
    "jose": "^6.2.1",
    "viem": "^2.23.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "prisma": "^6.5.0",
    "typescript": "^5.6.3"
  }
}